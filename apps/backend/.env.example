# Racetag Backend - environment variables
# Copy this file to .env and adjust values as needed

# Port used by the backend inside the container and on the host mapping
# Default is 8600 if not set
RACETAG_PORT=8600
RACETAG_API_KEY=your_api_key_here


# Total laps to complete a race
RACE_TOTAL_LAPS=5

# Defence-in-depth duplicate suppression (W-003 / P0-1): the backend rejects
# any arrive event for a tag that arrives within this many seconds of the
# previous accepted pass for that tag. Set lower than MIN_LAP_INTERVAL_S in
# reader-service so the reader-service cooldown is the primary gate.
RACE_MIN_PASS_INTERVAL_S=8