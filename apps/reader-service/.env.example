# Example environment for racetag-reader-service
# Copy to .env and adjust values.

# Reader connection
READER_IP=192.168.1.130
CONTROL_PORT=50007
EVENT_PORT=50008

# Behavior flags
NO_COLOR=false
INTERACTIVE=false
RAW=false

# Optional: path inside container to init commands file
# If unset, defaults to 'init_commands' bundled in the image
INIT_COMMANDS_FILE=/app/src/init_commands

# Backend configuration
# Transport: http (default) or mock
BACKEND_TRANSPORT=http
# Backend URL only required when transport=http. Example:
BACKEND_URL=http://localhost:8000
# Optional token for Authorization: Bearer <token>  --> Token type changed to X-API-Key for now
# Optional token for X-API-Key: <token>
BACKEND_TOKEN=changeme

# Minimum seconds between two forwarded arrive events for the same tag.
# Prevents multi-antenna double-counting (P0-1). Must be less than the
# shortest realistic lap time on your course.
MIN_LAP_INTERVAL_S=10
