# Example configuration commands for the Sirit INfinity 510
# Lines starting with # are ignored.
# This file is loaded AFTER reader.events.bind(id = <sessionId>) has been sent.
# You can copy this file to init_commands and edit it.

# Time zone configuration
info.time_zone=UTC

# Register the events
reader.events.unregister(name = event.tag.report)

reader.events.register(name = event.tag.arrive)
reader.events.register(name = event.tag.depart)
reader.events.register(name = event.tag.portal_cross)

# Reporting fields
tag.reporting.arrive_fields = tag_id time antenna rssi
# tag.reporting.depart_fields = tag_id type time antenna
tag.reporting.depart_fields = tag_id time antenna repeat
tag.reporting.portal_cross_fields = tag_id type time antenna rssi freq

tag.reporting.depart_time = 300  # milliseconds
tag.reporting.raw_tag_data = false


# Start collecting tags by setting the operating mode to active
setup.operating_mode=active
